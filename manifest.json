{
  "manifest_version": 3,
  "name": "Bookmark Duplicate Cleaner",
  "short_name": "Duplicate Cleaner",
  "version": "1.0.0",
  "description": "Fast bookmark duplicate removal tool.",
  "author": "BookmarkTools Team",
  "permissions": ["bookmarks", "storage", "alarms"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Remove Duplicate Bookmarks"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
